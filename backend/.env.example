# Copy to .env and fill in your values

# ── Supabase ──────────────────────────────────────────────────────────────────
SUPABASE_URL=https://zftnvydmjypmcjdsczjb.supabase.co
# Service Role Key — Supabase Dashboard > Settings > API > service_role
SUPABASE_SERVICE_KEY=your_service_role_key_here
# Anon key (needed for reference only, not used by backend)
SUPABASE_ANON_KEY=your_anon_key_here

# ── Frontend ──────────────────────────────────────────────────────────────────
# Frontend URL for CORS
FRONTEND_URL=http://localhost:5173

# ── Airtable ──────────────────────────────────────────────────────────────────
AIRTABLE_TOKEN=your_airtable_personal_access_token
AIRTABLE_BASE_ID=your_base_id
AIRTABLE_TABLE_ID=tblT7gyi0tZ51UKG4

# ── LLM (OpenAI-compatible) ───────────────────────────────────────────────────
OPENAI_BASE_URL=https://toknroutertybot.tybotflow.com/
OPENAI_API_KEY=your_openai_key_here

# ── Email (Resend) ─────────────────────────────────────────────────────────────
RESEND_API_KEY=re_your_key_here
FROM_EMAIL=noreply@ipisb.ma
